@page
@model ManuTrackAPI.Pages.Auth.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ManuTrack — Sign In</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f1f5f9;
            background-image:
                linear-gradient(rgba(14,165,233,0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(14,165,233,0.04) 1px, transparent 1px);
            background-size: 40px 40px;
            padding: 2rem;
        }

        .login-wrapper {
            width: 100%;
            max-width: 400px;
        }

        .brand {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            margin-bottom: 2rem;
        }

        .brand-icon {
            width: 38px; height: 38px;
            background: #0ea5e9;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.05rem;
            font-weight: 700;
            color: #fff;
        }

        .brand-name {
            font-size: 1.2rem;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: -0.4px;
        }

        .card {
            background: #ffffff;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 32px rgba(0,0,0,0.07), 0 1px 4px rgba(0,0,0,0.04);
            padding: 2.25rem 2rem;
        }

        .card-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: -0.3px;
            margin-bottom: 0.3rem;
        }

        .card-sub {
            font-size: 0.8rem;
            color: #94a3b8;
            margin-bottom: 1.75rem;
        }

        .field { margin-bottom: 1rem; }

        .field label {
            display: block;
            font-size: 0.76rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.4rem;
            letter-spacing: 0.1px;
        }

        .input-wrap { position: relative; }

        .input-wrap i {
            position: absolute;
            left: 0.8rem;
            top: 50%;
            transform: translateY(-50%);
            color: #cbd5e1;
            font-size: 0.85rem;
            pointer-events: none;
        }

        .input-wrap input {
            width: 100%;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.875rem;
            color: #0f172a;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 0.62rem 0.875rem 0.62rem 2.35rem;
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
        }

        .input-wrap input:focus {
            border-color: #0ea5e9;
            box-shadow: 0 0 0 3px rgba(14,165,233,0.1);
            background: #fff;
        }

        .input-wrap input::placeholder { color: #94a3b8; }

        .btn-submit {
            width: 100%;
            background: #0ea5e9;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.875rem;
            font-weight: 600;
            padding: 0.68rem;
            cursor: pointer;
            transition: background 0.15s, transform 0.1s;
            margin-top: 0.5rem;
        }

        .btn-submit:hover { background: #0284c7; }
        .btn-submit:active { transform: scale(0.99); }

        .error-msg {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 8px;
            padding: 0.6rem 0.875rem;
            font-size: 0.8rem;
            color: #dc2626;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.25rem;
        }

        .bottom-link {
            text-align: center;
            margin-top: 1.25rem;
            font-size: 0.78rem;
            color: #94a3b8;
        }

        .bottom-link a {
            color: #0ea5e9;
            font-weight: 600;
            text-decoration: none;
        }

        .bottom-link a:hover { text-decoration: underline; }

        .footer-note {
            text-align: center;
            margin-top: 2rem;
            font-size: 0.72rem;
            color: #cbd5e1;
        }
    </style>
</head>
<body>
<div class="login-wrapper">

    <div class="brand">
        <div class="brand-icon">M</div>
        <span class="brand-name">ManuTrack</span>
    </div>

    <div class="card">
        <div class="card-title">Welcome back</div>
        <div class="card-sub">Sign in to your account to continue.</div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error-msg">
                <i class="bi bi-exclamation-circle-fill"></i>
                @Model.ErrorMessage
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="field">
                <label>Email Address</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope"></i>
                    <input type="email" name="Email"
                           value="@Model.Email"
                           placeholder="you@company.com" required />
                </div>
            </div>
            <div class="field">
                <label>Password</label>
                <div class="input-wrap">
                    <i class="bi bi-lock"></i>
                    <input type="password" name="Password"
                           placeholder="Enter your password" required />
                </div>
            </div>
            <button type="submit" class="btn-submit">Sign In</button>
        </form>
    </div>

    <div class="bottom-link">
        First time here? <a href="/Auth/Register">Register as Admin</a>
    </div>

    <div class="footer-note">
        © 2026 ManuTrack · Manufacturing Operations Platform
    </div>

</div>
</body>
</html>