<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ManuTrack — @(ViewData["Title"] ?? "Manufacturing Operations")</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --sidebar-bg: #1e2533;
            --sidebar-width: 220px;
            --navbar-height: 56px;
            --accent: #0ea5e9;
            --accent-hover: #0284c7;
            --surface: #f1f5f9;
            --card-bg: #ffffff;
            --text-primary: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--surface);
            color: var(--text-primary);
            margin: 0;
        }

        /* ── NAVBAR ── */
        .app-navbar {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: var(--navbar-height);
            background: var(--sidebar-bg);
            display: flex;
            align-items: center;
            padding: 0 1.25rem 0 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .app-brand {
            width: var(--sidebar-width);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0 1.25rem;
            text-decoration: none;
            flex-shrink: 0;
        }

        .app-brand-icon {
            width: 30px; height: 30px;
            background: var(--accent);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            color: white;
            font-weight: 700;
        }

        .app-brand-name {
            font-size: 1.05rem;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: -0.3px;
        }

        .navbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .navbar-user {
            font-size: 0.82rem;
            color: #94a3b8;
            font-weight: 500;
        }

        .logout-btn {
            font-size: 0.8rem;
            padding: 0.3rem 0.85rem;
            border-radius: 6px;
            border: 1px solid rgba(255,255,255,0.15);
            color: #cbd5e1;
            background: transparent;
            text-decoration: none;
            transition: all 0.15s;
            font-weight: 500;
        }

        .logout-btn:hover {
            background: rgba(255,255,255,0.08);
            color: #fff;
            border-color: rgba(255,255,255,0.25);
        }

        /* ── ROLE BADGES ── */
        .role-badge {
            font-size: 0.7rem;
            font-weight: 600;
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
            letter-spacing: 0.3px;
        }

        .role-Admin       { background: #dc2626; color: #fff; }
        .role-Planner     { background: var(--accent); color: #fff; }
        .role-Operator    { background: #16a34a; color: #fff; }
        .role-Inspector   { background: #d97706; color: #fff; }
        .role-InventoryManager  { background: #7c3aed; color: #fff; }
        .role-ComplianceOfficer { background: #0f766e; color: #fff; }

        /* ── SIDEBAR ── */
        .app-sidebar {
            position: fixed;
            top: var(--navbar-height);
            left: 0;
            width: var(--sidebar-width);
            height: calc(100vh - var(--navbar-height));
            background: var(--sidebar-bg);
            padding: 1rem 0.75rem;
            overflow-y: auto;
            z-index: 999;
            display: flex;
            flex-direction: column;
        }

        .sidebar-section-label {
            font-size: 0.65rem;
            font-weight: 600;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            padding: 0.75rem 0.6rem 0.35rem;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            padding: 0.55rem 0.75rem;
            border-radius: 8px;
            color: #94a3b8;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: all 0.15s;
            margin-bottom: 2px;
        }

        .sidebar-link i {
            font-size: 1rem;
            width: 18px;
            text-align: center;
            flex-shrink: 0;
        }

        .sidebar-link:hover {
            background: rgba(255,255,255,0.07);
            color: #e2e8f0;
        }

        .sidebar-link.active {
            background: rgba(14,165,233,0.15);
            color: var(--accent);
        }

        .sidebar-divider {
            border: none;
            border-top: 1px solid rgba(255,255,255,0.06);
            margin: 0.5rem 0;
        }

        .sidebar-bottom {
            margin-top: auto;
            padding-top: 0.5rem;
            border-top: 1px solid rgba(255,255,255,0.06);
        }

        /* ── MAIN CONTENT ── */
        .app-main {
            margin-left: var(--sidebar-width);
            margin-top: var(--navbar-height);
            min-height: calc(100vh - var(--navbar-height));
            padding: 1.75rem 2rem;
        }

        /* ── CARDS ── */
        .card {
            border: 1px solid var(--border) !important;
            border-radius: 10px !important;
        }

        .card-header {
            border-bottom: 1px solid var(--border) !important;
            padding: 0.85rem 1.25rem !important;
            font-size: 0.875rem;
        }

        /* ── TABLES ── */
        .table { font-size: 0.85rem; }
        .table thead th {
            font-weight: 600;
            color: var(--text-muted);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ── BUTTONS ── */
        .btn-primary {
            background: var(--accent) !important;
            border-color: var(--accent) !important;
        }
        .btn-primary:hover {
            background: var(--accent-hover) !important;
            border-color: var(--accent-hover) !important;
        }

        /* ── ALERTS ── */
        .alert { border-radius: 8px; font-size: 0.875rem; }

        /* ── FORM CONTROLS ── */
        .form-control, .form-select {
            font-size: 0.875rem;
            border-color: var(--border);
            border-radius: 7px;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(14,165,233,0.12);
        }

        /* ── BADGES ── */
        .badge { font-weight: 500; border-radius: 5px; }

        /* ── PAGE TITLE ── */
        .page-title {
            font-size: 1.35rem;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.3px;
        }

        /* ── NO LOGGED IN PAGES (login/register) ── */
        .auth-page {
            min-height: 100vh;
            background: var(--surface);
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>

@{
    var currentPath = Context.Request.Path.Value ?? "";
    var role = Context.Session.GetString("role") ?? "";
}

@if (Context.Session.GetString("token") != null)
{
    <!-- NAVBAR -->
    <nav class="app-navbar">
        <a class="app-brand" href="/Dashboard/Index">
            <div class="app-brand-icon">M</div>
            <span class="app-brand-name">ManuTrack</span>
        </a>
        <div class="navbar-right">
            <span class="navbar-user">@Context.Session.GetString("name")</span>
            @{
                var userRole = Context.Session.GetString("role") ?? "";
            }
            <span class="role-badge role-@userRole">@userRole</span>
            <a href="/Auth/Logout" class="logout-btn">
                <i class="bi bi-box-arrow-right me-1"></i>Logout
            </a>
        </div>
    </nav>

    <!-- SIDEBAR -->
    <aside class="app-sidebar">
        <div>
            <span class="sidebar-section-label">Main</span>

            <a href="/Dashboard/Index"
               class="sidebar-link @(currentPath.StartsWith("/Dashboard") ? "active" : "")">
                <i class="bi bi-grid-1x2"></i>Dashboard
            </a>

            @if (role == "Admin" || role == "Planner")
            {
                <a href="/Products/Index"
                   class="sidebar-link @(currentPath.StartsWith("/Products") ? "active" : "")">
                    <i class="bi bi-box-seam"></i>Products & BOM
                </a>
            }

            <a href="/WorkOrders/Index"
               class="sidebar-link @(currentPath.StartsWith("/WorkOrders") ? "active" : "")">
                <i class="bi bi-clipboard2-check"></i>Work Orders
            </a>

            @if (role == "Admin")
            {
                <hr class="sidebar-divider" />
                <span class="sidebar-section-label">Management</span>

                <a href="/Users/Index"
                   class="sidebar-link @(currentPath.StartsWith("/Users") ? "active" : "")">
                    <i class="bi bi-people"></i>Users
                </a>

                <a href="/Auth/AuditLogs"
                   class="sidebar-link @(currentPath.StartsWith("/Auth/AuditLogs") ? "active" : "")">
                    <i class="bi bi-journal-text"></i>Audit Logs
                </a>
            }

            @if (role == "ComplianceOfficer")
            {
                <hr class="sidebar-divider" />
                <span class="sidebar-section-label">Compliance</span>

                <a href="/Auth/AuditLogs"
                   class="sidebar-link @(currentPath.StartsWith("/Auth/AuditLogs") ? "active" : "")">
                    <i class="bi bi-journal-text"></i>Audit Logs
                </a>
            }
        </div>

        <div class="sidebar-bottom">
            <a href="/Profile/Index"
               class="sidebar-link @(currentPath.StartsWith("/Profile") ? "active" : "")">
                <i class="bi bi-person-circle"></i>My Profile
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="app-main">
        @RenderBody()
    </main>
}
else
{
    <div class="auth-page">
        @RenderBody()
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>